{
  "request": {
    "method": "POST",
    "urlPath": "/api/anything",
    "headers": {
      "Content-Type": {
        "equalTo": "application/json"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json",
      "Access-Control-Allow-Origin": "*",
      "Connection": "keep-alive"
    },
    "bodyFileName": "anything-response.json"
  }
}

